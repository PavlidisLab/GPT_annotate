replicate/data/efo_*.obo
replicate/data/efo.obo
replicate/data/tgemo.owl
replicate/data/tgemo.obo
replicate/data/geo_cache/
replicate/data/paper_cache/

# cell-line bulk downloads + derived indexes (regenerable via build_cell_line_*)
replicate/data/CLO.obo
replicate/data/CLO.owl
replicate/data/robot.jar
replicate/data/cell_line_terms.json
replicate/data/cell_line_list.json
replicate/data/cell_line_main_frame.tsv
