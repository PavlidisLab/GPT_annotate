.Rproj.user
.Rhistory
.RData
.Ruserdata
.DS_Store
**/.DS_Store
.claude/
.obsidian/

# Python virtual environments + bytecode anywhere in the tree
**/.venv/
**/__pycache__/

# ---------------------------------------------------------------------------
# revisions/  — keep code + small reproducibility artefacts, exclude bulk
# downloads, paid-API artefacts, and per-experiment LLM outputs (those
# live in the Zenodo deposit, not in git)
# ---------------------------------------------------------------------------

# Public archival downloads (regenerable via build_*_list.R / prefetch_geo.py)
revisions/data/efo*.obo
revisions/data/tgemo.owl
revisions/data/tgemo.obo
revisions/data/CLO.obo
revisions/data/CLO.owl
revisions/data/robot.jar
revisions/data/geo_cache/
revisions/data/paper_cache/

# Gemma REST API metadata cache (regenerable via gemma_fetch.py)
revisions/data/gemma_cache/

# OpenAI embeddings and derived dense indexes (paid API; reproduced
# only by re-spending ~$10 — ship via Zenodo instead)
revisions/data/cell_line_embeddings*.npy
revisions/data/cell_line_embeddings*.npz
revisions/data/cell_line_embedding_ids.json*
revisions/data/cell_line_bm25.pkl
revisions/data/cell_line_isa.json
revisions/data/cell_line_terms.json
revisions/data/cell_line_list.json
revisions/data/cell_line_xrefs.json

# Large derived TSVs (data, not code; regenerable via build scripts)
revisions/data/cell_line_main_frame.tsv
revisions/data/strain_main_frame.tsv
revisions/data/long_curation_sheet.tsv
revisions/data/sonnet_curation_sheet.tsv

# Per-experiment LLM outputs + per-task analysis caches
# (thousands of JSON files; ship via Zenodo)
revisions/data/results/
revisions/data/results_cl/
revisions/data/analysis/
revisions/data/cache/

# SapBERT model + embedding cache (regenerable from HuggingFace checkpoint)
revisions/data/cache/
revisions/.cache/

# Pre-fix backup directories the SapBERT rerun script creates
revisions/data/results/*.prefix_*/
revisions/data/results/sapbert_*.prefix_*/

# Lab-internal interpretation notes (not part of the public record)
revisions/FINDINGS.md
revisions/SENSITIVITY_ANALYSES.md

# Accidental nested 'revisions/revisions/' from a script that ran with
# the wrong cwd (424 MB of GEO/PMC re-downloads); ignore so we don't
# track it. Safe to delete from disk.
revisions/revisions/
